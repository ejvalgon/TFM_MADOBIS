    ALL_TARGETS += expand(os.path.join(OUT_ROOT, "split_bam/idxstats", "{sample}.main.postrename.idxstats.txt"), sample=SAMPLES)
    ALL_TARGETS += expand(os.path.join(OUT_ROOT, "split_bam/idxstats", "{sample}.spikein.idxstats.txt"), sample=SAMPLES)

    # Spike-in read counts and normalization factors
    ALL_TARGETS += [
        os.path.join(OUT_ROOT, "spikein_counts", "spike_reads_table.tsv"),
        os.path.join(OUT_ROOT, "spikein_counts", "scale_factors.tsv")
    ]

    # Spike-in-normalized bigWig tracks
    ALL_TARGETS += expand(os.path.join(OUT_ROOT, "bigwig_spikein_median", "{sample}.coverage.spikein_median.bw"), sample=SAMPLES)
    ALL_TARGETS += expand(os.path.join(OUT_ROOT, "bigwig_spikein_deseq2", "{sample}.coverage.spikein_deseq2.bw"), sample=SAMPLES)

    # Summary matrices from spike-in-normalized bigWigs
    ALL_TARGETS += [
        os.path.join(OUT_ROOT, "multiBigwigSummary", f"{config['GSE']}_multiBigwigSummary.spikein_median.npz"),
        os.path.join(OUT_ROOT, "multiBigwigSummary", f"{config['GSE']}_multiBigwigSummary.spikein_median.txt"),
        os.path.join(OUT_ROOT, "multiBigwigSummary", f"{config['GSE']}_multiBigwigSummary.spikein_deseq2.npz"),
        os.path.join(OUT_ROOT, "multiBigwigSummary", f"{config['GSE']}_multiBigwigSummary.spikein_deseq2.txt")
    ]

    # Normalized-signal correlation and PCA plots
    ALL_TARGETS += [
        os.path.join(QC_ROOT, "reproducibility", "normalized_signal", "spikein_median", "correlation", f"{config['GSE']}.spikein_median.spearman_heatmap.pdf"),
        os.path.join(QC_ROOT, "reproducibility", "normalized_signal", "spikein_median", "correlation", f"{config['GSE']}.spikein_median.spearman_matrix.tab"),
        os.path.join(QC_ROOT, "reproducibility", "normalized_signal", "spikein_median", "PCA", f"{config['GSE']}.spikein_median.PCA.pdf"),
        os.path.join(QC_ROOT, "reproducibility", "normalized_signal", "spikein_median", "PCA", f"{config['GSE']}.spikein_median.PCA.tab"),

        os.path.join(QC_ROOT, "reproducibility", "normalized_signal", "spikein_deseq2", "correlation", f"{config['GSE']}.spikein_deseq2.spearman_heatmap.pdf"),
        os.path.join(QC_ROOT, "reproducibility", "normalized_signal", "spikein_deseq2", "correlation", f"{config['GSE']}.spikein_deseq2.spearman_matrix.tab"),
        os.path.join(QC_ROOT, "reproducibility", "normalized_signal", "spikein_deseq2", "PCA", f"{config['GSE']}.spikein_deseq2.PCA.pdf"),
        os.path.join(QC_ROOT, "reproducibility", "normalized_signal", "spikein_deseq2", "PCA", f"{config['GSE']}.spikein_deseq2.PCA.tab")
    ]

else:
    # CPM-normalized workflow outputs are generated when spike-in normalization is not enabled.

    # CPM-normalized bigWig tracks
    ALL_TARGETS += expand(os.path.join(OUT_ROOT, "bigwig", "{sample}.coverage.bw"), sample=SAMPLES)

    # Summary matrices from CPM-normalized bigWigs
    ALL_TARGETS += [
        os.path.join(OUT_ROOT, "multiBigwigSummary", f"{config['GSE']}_multiBigwigSummary.npz"),
        os.path.join(OUT_ROOT, "multiBigwigSummary", f"{config['GSE']}_multiBigwigSummary.txt")
    ]

    # Normalized-signal correlation and PCA plots
    ALL_TARGETS += [
        os.path.join(QC_ROOT, "reproducibility", "normalized_signal", "CPM", "correlation", f"{config['GSE']}.CPM.spearman_heatmap.pdf"),
        os.path.join(QC_ROOT, "reproducibility", "normalized_signal", "CPM", "correlation", f"{config['GSE']}.CPM.spearman_matrix.tab"),
        os.path.join(QC_ROOT, "reproducibility", "normalized_signal", "CPM", "PCA", f"{config['GSE']}.CPM.PCA.pdf"),
        os.path.join(QC_ROOT, "reproducibility", "normalized_signal", "CPM", "PCA", f"{config['GSE']}.CPM.PCA.tab")
    ]


# ------------------------------------------------------------------------------
# Peak calling and peak-level analysis outputs
# ------------------------------------------------------------------------------
# When enabled, this block collects the final outputs generated by the peak calling
# module: per-sample MACS3 peaks, consensus and union peak sets, count matrices,
# FRiP metrics, peak-level QC summaries and signal heatmaps.

if calling_peaks == "yes":

    # Per-sample MACS3 peak calls
    ALL_TARGETS += expand(
        os.path.join(OUT_ROOT, "peaks", "macs3", "narrow", "{sample}", "{sample}_peaks.narrowPeak"),
        sample=NARROW_SAMPLES
    )

    ALL_TARGETS += expand(
        os.path.join(OUT_ROOT, "peaks", "macs3", "broad", "{sample}", "{sample}_peaks.broadPeak"),
        sample=BROAD_SAMPLES
    )

    # Condition-level consensus peak sets
    ALL_TARGETS += expand(
        os.path.join(OUT_ROOT, "peaks", "consensus", "{peak_mode}", "{mark}", "{condition}.{mark}.{peak_mode}.consensus.bed"),
        zip,
        peak_mode=CONSENSUS_PEAK_MODES,
        mark=CONSENSUS_MARKS,
        condition=CONSENSUS_CONDITIONS
    )

    ALL_TARGETS += expand(
        os.path.join(OUT_ROOT, "peaks", "consensus", "{peak_mode}", "{mark}", "{condition}.{mark}.{peak_mode}.multiinter.bed"),
        zip,
        peak_mode=CONSENSUS_PEAK_MODES,
        mark=CONSENSUS_MARKS,
        condition=CONSENSUS_CONDITIONS
    )

    ALL_TARGETS += expand(
        os.path.join(QC_ROOT, "peaks", "consensus", "{condition}.{mark}.{peak_mode}.consensus.summary.tsv"),
        zip,
        condition=CONSENSUS_CONDITIONS,
        mark=CONSENSUS_MARKS,
        peak_mode=CONSENSUS_PEAK_MODES
    )

    # Mark-level union peak sets
    ALL_TARGETS += expand(
        os.path.join(OUT_ROOT, "peaks", "union", "{peak_mode}", "{mark}", "{mark}.{peak_mode}.union_peaks.bed"),
        zip,
        peak_mode=UNION_PEAK_MODES,
        mark=UNION_MARKS
    )

    ALL_TARGETS += expand(
        os.path.join(QC_ROOT, "peaks", "union", "{mark}.{peak_mode}.union_peaks.summary.tsv"),
        zip,
        peak_mode=UNION_PEAK_MODES,
        mark=UNION_MARKS
    )

    # Peak count matrices over union peak sets
    ALL_TARGETS += expand(
        os.path.join(OUT_ROOT, "peaks", "counts", "{peak_mode}", "{mark}", "{mark}.{peak_mode}.union_peaks.saf"),
        zip,
        peak_mode=UNION_PEAK_MODES,
        mark=UNION_MARKS
    )

    ALL_TARGETS += expand(
        os.path.join(OUT_ROOT, "peaks", "counts", "{peak_mode}", "{mark}", "{mark}.{peak_mode}.featureCounts.raw.tsv"),
        zip,
        peak_mode=UNION_PEAK_MODES,
        mark=UNION_MARKS
    )

    ALL_TARGETS += expand(
        os.path.join(OUT_ROOT, "peaks", "counts", "{peak_mode}", "{mark}", "{mark}.{peak_mode}.featureCounts.raw.tsv.summary"),
        zip,
        peak_mode=UNION_PEAK_MODES,
        mark=UNION_MARKS
    )

    ALL_TARGETS += expand(
        os.path.join(OUT_ROOT, "peaks", "counts", "{peak_mode}", "{mark}", "{mark}.{peak_mode}.counts_matrix.tsv"),
        zip,
        peak_mode=UNION_PEAK_MODES,
        mark=UNION_MARKS
    )

    ALL_TARGETS += expand(
        os.path.join(QC_ROOT, "peaks", "counts", "{mark}.{peak_mode}.counts.summary.tsv"),
        zip,
        peak_mode=UNION_PEAK_MODES,
        mark=UNION_MARKS
    )

    # Peak-level QC summaries
    ALL_TARGETS += expand(
        os.path.join(QC_ROOT, "peaks", "individual", "{sample}.narrow.peak_qc.tsv"),
        sample=NARROW_SAMPLES
    )

    ALL_TARGETS += expand(
        os.path.join(QC_ROOT, "peaks", "individual", "{sample}.broad.peak_qc.tsv"),
        sample=BROAD_SAMPLES
    )

    ALL_TARGETS += expand(
        os.path.join(QC_ROOT, "peaks", "consensus", "{condition}.{mark}.{peak_mode}.peak_qc.tsv"),
        zip,
        condition=CONSENSUS_CONDITIONS,
        mark=CONSENSUS_MARKS,
        peak_mode=CONSENSUS_PEAK_MODES
    )

    # FRiP metrics
    ALL_TARGETS += expand(
        os.path.join(QC_ROOT, "peaks", "frip", "individual", "{sample}.narrow.frip.tsv"),
        sample=NARROW_SAMPLES
    )

    ALL_TARGETS += expand(
        os.path.join(QC_ROOT, "peaks", "frip", "individual", "{sample}.broad.frip.tsv"),
        sample=BROAD_SAMPLES
    )

    ALL_TARGETS += expand(
        os.path.join(QC_ROOT, "peaks", "frip", "consensus", "{sample}.narrow.consensus_frip.tsv"),
        sample=NARROW_SAMPLES
    )

    ALL_TARGETS += expand(
        os.path.join(QC_ROOT, "peaks", "frip", "consensus", "{sample}.broad.consensus_frip.tsv"),
        sample=BROAD_SAMPLES
    )

    # Signal heatmaps over union peaks
    # Heatmap inputs depend on the normalization strategy used to generate bigWigs.
    if spikeIN == "yes":

        ALL_TARGETS += expand(
            os.path.join(QC_ROOT, "peaks", "signal_heatmap", "spikein_median", "{peak_mode}", "{mark}.{peak_mode}.heatmap.pdf"),
            zip,
            peak_mode=UNION_PEAK_MODES,
            mark=UNION_MARKS
        )

        ALL_TARGETS += expand(
            os.path.join(QC_ROOT, "peaks", "signal_heatmap", "spikein_deseq2", "{peak_mode}", "{mark}.{peak_mode}.heatmap.pdf"),
            zip,
            peak_mode=UNION_PEAK_MODES,
            mark=UNION_MARKS
        )

    else:

        ALL_TARGETS += expand(
            os.path.join(QC_ROOT, "peaks", "signal_heatmap", "CPM", "{peak_mode}", "{mark}.{peak_mode}.heatmap.pdf"),
            zip,
            peak_mode=UNION_PEAK_MODES,
            mark=UNION_MARKS
        )

# ------------------------------------------------------------------------------
# Final MultiQC report
# ------------------------------------------------------------------------------
# MultiQC integrates the QC outputs generated across the enabled workflow modules.

ALL_TARGETS += [
    os.path.join(QC_ROOT, "multiqc", f"{config['GSE']}_multiqc_report.html")
]

rule all:
    input:
        ALL_TARGETS

