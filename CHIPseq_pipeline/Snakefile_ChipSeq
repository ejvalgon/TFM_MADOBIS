# ------------------------------------------------------------------------------
# Peak calling metadata and target groups
# ------------------------------------------------------------------------------
# When peak calling is enabled, the metadata table is loaded and validated here.
# This block defines which IP samples require narrow and/or broad peak calling,
# as well as the consensus and union peak groups used by downstream rules.

calling_peaks = str(config["calling_peaks"]).strip().lower()

if calling_peaks not in ["yes", "no"]:
    raise ValueError("ERROR: calling_peaks must be either 'yes' or 'no'.")

if calling_peaks == "yes":

    METADATA = pd.read_csv(config["metadata"], sep="\t").fillna("")

    required_cols = ["sample", "role", "condition", "mark", "replicate", "control", "peak_type"]

    for col in required_cols:
        if col not in METADATA.columns:
            raise ValueError(f"ERROR: metadata file is missing required column: {col}")

    METADATA["sample"] = METADATA["sample"].astype(str).str.strip()
    METADATA["role"] = METADATA["role"].astype(str).str.strip().str.upper()
    METADATA["condition"] = METADATA["condition"].astype(str).str.strip()
    METADATA["mark"] = METADATA["mark"].astype(str).str.strip()
    METADATA["control"] = METADATA["control"].astype(str).str.strip()
    METADATA["peak_type"] = METADATA["peak_type"].astype(str).str.strip().str.lower()

    for sample in METADATA["sample"]:
        if sample not in SAMPLES:
            raise ValueError(f"ERROR: sample '{sample}' is present in metadata but not in SAMPLES/config.")

    valid_roles = ["IP", "INPUT"]

    for _, row in METADATA.iterrows():
        if row["role"] not in valid_roles:
            raise ValueError(f"ERROR: sample '{row['sample']}' has invalid role: {row['role']}")

    valid_peak_types = ["narrow", "broad", "both"]

    for _, row in METADATA.loc[METADATA["role"] == "IP"].iterrows():
        if row["peak_type"] not in valid_peak_types:
            raise ValueError(f"ERROR: IP sample '{row['sample']}' has invalid peak_type: {row['peak_type']}")

    for _, row in METADATA.loc[METADATA["role"] == "INPUT"].iterrows():
        if row["peak_type"] != "none":
            raise ValueError(f"ERROR: Input sample '{row['sample']}' should have peak_type = none.")

    for _, row in METADATA.loc[METADATA["role"] == "IP"].iterrows():
        control = row["control"]

        if control != "" and control not in METADATA["sample"].tolist():
            raise ValueError(f"ERROR: control '{control}' for sample '{row['sample']}' is not present in metadata.")

        if control != "":
            control_role = METADATA.loc[METADATA["sample"] == control, "role"].iloc[0]

            if control_role != "INPUT":
                raise ValueError(
                    f"ERROR: control '{control}' for sample '{row['sample']}' is not annotated as INPUT."
                )

    NARROW_SAMPLES = METADATA.loc[
        (METADATA["role"] == "IP") & (METADATA["peak_type"].isin(["narrow", "both"])),
        "sample"
    ].tolist()

    BROAD_SAMPLES = METADATA.loc[
        (METADATA["role"] == "IP") & (METADATA["peak_type"].isin(["broad", "both"])),
        "sample"
    ].tolist()

    # MACS3 input format depends on the sequencing layout.
    MACS_FORMAT = "BAMPE" if LAYOUT == "PAIRED" else "BAM"

    # Consensus peak groups are defined by condition, mark and peak mode.
    CONSENSUS_GROUPS = []

    for peak_mode in ["narrow", "broad"]:
        group_metadata = METADATA.loc[
            (METADATA["role"] == "IP") &
            (METADATA["peak_type"].isin([peak_mode, "both"]))
        ]

        for _, row in group_metadata[["condition", "mark"]].drop_duplicates().iterrows():
            CONSENSUS_GROUPS.append({
                "peak_mode": peak_mode,
                "condition": row["condition"],
                "mark": row["mark"]
            })

    CONSENSUS_PEAK_MODES = [g["peak_mode"] for g in CONSENSUS_GROUPS]
    CONSENSUS_CONDITIONS = [g["condition"] for g in CONSENSUS_GROUPS]
    CONSENSUS_MARKS = [g["mark"] for g in CONSENSUS_GROUPS]

    # Union peak groups are defined by mark and peak mode.
    UNION_GROUPS = []

    for peak_mode in ["narrow", "broad"]:
        group_metadata = METADATA.loc[
            (METADATA["role"] == "IP") &
            (METADATA["peak_type"].isin([peak_mode, "both"]))
        ]

        for mark in group_metadata["mark"].drop_duplicates().tolist():
            UNION_GROUPS.append({
                "peak_mode": peak_mode,
                "mark": mark
            })

    UNION_PEAK_MODES = [g["peak_mode"] for g in UNION_GROUPS]
    UNION_MARKS = [g["mark"] for g in UNION_GROUPS]

# ------------------------------------------------------------------------------
# Peak calling helper functions
# ------------------------------------------------------------------------------
# These functions dynamically provide rule inputs based on the metadata table.
# They are defined only when peak calling is enabled.

if calling_peaks == "yes":

    def get_control_bam(wc):
        """
        Return the input/control BAM associated with an IP sample, if available.
        """
        control = METADATA.loc[METADATA["sample"] == wc.sample, "control"].iloc[0]

        if control == "":
            return []

        return os.path.join(MAIN_BAM_DIR, f"{control}.bam")

    def get_peaks_for_consensus(wc):
        """
        Return per-sample MACS3 peak files belonging to a consensus peak group.
        """
        samples = METADATA.loc[
            (METADATA["role"] == "IP") &
            (METADATA["condition"] == wc.condition) &
            (METADATA["mark"] == wc.mark) &
            (METADATA["peak_type"].isin([wc.peak_mode, "both"])),
            "sample"
        ].tolist()

        if len(samples) == 0:
            raise ValueError(
                f"ERROR: no samples found for consensus group: "
                f"condition={wc.condition}, mark={wc.mark}, peak_mode={wc.peak_mode}"
            )

        return [
            os.path.join(OUT_ROOT, "peaks", "macs3", wc.peak_mode, sample, f"{sample}_peaks.{wc.peak_mode}Peak")
            for sample in samples
        ]

    def get_consensus_for_sample(wc):
        """
        Return the consensus peak file corresponding to a given sample and peak mode.
        """
        condition = METADATA.loc[METADATA["sample"] == wc.sample, "condition"].iloc[0]
        mark = METADATA.loc[METADATA["sample"] == wc.sample, "mark"].iloc[0]

        return os.path.join(
            OUT_ROOT,
            "peaks",
            "consensus",
            wc.peak_mode,
            mark,
            f"{condition}.{mark}.{wc.peak_mode}.consensus.bed"
        )

    def get_consensus_peaks_for_union(wc):
        """
        Return condition-level consensus peak files used to build a union peak set.
        """
        conditions = METADATA.loc[
            (METADATA["role"] == "IP") &
            (METADATA["mark"] == wc.mark) &
            (METADATA["peak_type"].isin([wc.peak_mode, "both"])),
            "condition"
        ].drop_duplicates().tolist()

        if len(conditions) == 0:
            raise ValueError(
                f"ERROR: no consensus peak groups found for union: "
                f"mark={wc.mark}, peak_mode={wc.peak_mode}"
            )

        return [
            os.path.join(
                OUT_ROOT,
                "peaks",
                "consensus",
                wc.peak_mode,
                wc.mark,
                f"{condition}.{wc.mark}.{wc.peak_mode}.consensus.bed"
            )
            for condition in conditions
        ]

    def get_samples_for_union_counts(wc):
        """
        Return IP samples included in the peak count matrix for a mark and peak mode.
        """
        samples = METADATA.loc[
            (METADATA["role"] == "IP") &
            (METADATA["mark"] == wc.mark) &
            (METADATA["peak_type"].isin([wc.peak_mode, "both"])),
            "sample"
        ].tolist()

        if len(samples) == 0:
            raise ValueError(
                f"ERROR: no IP samples found for count matrix: "
                f"mark={wc.mark}, peak_mode={wc.peak_mode}"
            )

        return samples

