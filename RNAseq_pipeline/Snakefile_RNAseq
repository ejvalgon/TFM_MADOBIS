# ==============================================================================
# Bulk RNA-seq Snakemake workflow
# ==============================================================================
# This Snakefile defines the global configuration, sample discovery logic,
# final workflow targets and module imports for the bulk RNA-seq pipeline.
#
# The actual processing and quality control rules are implemented in separate
# workflow modules:
#   - workflow/workflow_RNAseq.smk
#   - workflow/qc_RNAseqc.smk
# ==============================================================================

# ------------------------------------------------------------------------------
# Imports
# ------------------------------------------------------------------------------

import glob
import os

