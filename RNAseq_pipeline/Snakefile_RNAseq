# Project-level paths
# ------------------------------------------------------------------------------

# Root directory from which the workflow is executed.
PROJECT_DIR = os.getcwd()

# Directory containing Conda environment YAML files.
ENV_DIR = os.path.join(PROJECT_DIR, "envs")

# Directory containing custom helper scripts used by the workflow.
SCRIPT_DIR = os.path.join(PROJECT_DIR, "scripts")

